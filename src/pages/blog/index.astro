---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="Blog | Manas Kinkar"
  description="Technical notes and project updates by Manas Kinkar."
  path="/blog/"
>
  <section class="container py-5">
    <h1 class="mb-3">Blog</h1>
    <p class="text-muted mb-4">
      Notes on development, experiments, and lessons learned while building software.
    </p>
    <div class="d-grid gap-3">
      {
        posts.map((post) => (
          <article class="card">
            <div class="card-body">
              <h2 class="h4 card-title">
                <a href={`/blog/${post.slug}/`} class="text-decoration-none">{post.data.title}</a>
              </h2>
              <p class="card-text text-muted mb-2">{post.data.description}</p>
              <p class="mb-0">
                <small>{post.data.pubDate.toLocaleDateString()}</small>
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
