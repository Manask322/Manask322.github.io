---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Manas Kinkar | Developer Portfolio"
  description="Developer portfolio of Manas Kinkar."
  path="/"
>
  <section class="container py-5">
    <div class="row align-items-center g-4">
      <div class="col-lg-6">
        <h1 class="hero-title fw-bold mb-3">Hi, I am Manas Kinkar.</h1>
        <p class="lead text-muted mb-4">
          A developer.
        </p>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-info" href="/projects/">Projects</a>
          <a class="btn btn-outline-light" href="/blogs/">Blog</a>
          <a class="btn btn-outline-light" href="/experience/">Experience</a>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <img
          class="profile-image mx-auto d-block"
          src="https://avatars0.githubusercontent.com/u/32352247?s=400&v=4"
          alt="Manas Kinkar"
          loading="eager"
          decoding="async"
          style="max-width: 300px; width: 100%;"
        />
      </div>
    </div>
  </section>
</BaseLayout>
