---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Manas Kinkar | Lead Software Development Engineer"
  description="Lead Software Development Engineer at Razorpay with 5+ years experience in UPI payment systems, Go, and distributed systems."
  path="/"
>
  <section class="container py-5">
    <div class="row align-items-center g-4">
      <div class="col-lg-6">
        <h1 class="hero-title fw-bold mb-3">Hi, I am Manas Kinkar.</h1>
        <p class="lead text-muted mb-4">
          Lead Software Development Engineer at Razorpay with 5+ years experience building and scaling high-performance UPI payment systems.
        </p>
        <div class="mb-4">
          <p class="mb-2"><strong>Current Role:</strong> Lead SDE at Razorpay</p>
          <p class="mb-2"><strong>Expertise:</strong> UPI Payments, Go, Kubernetes, Distributed Systems</p>
          <p class="mb-0"><strong>Education:</strong> B.Tech IT, NITK (2016-2020)</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-info" href="/experience/">Experience</a>
          <a class="btn btn-outline-light" href="/projects/">Projects</a>
          <a class="btn btn-outline-light" href="/blogs/">Blog</a>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <img
          class="profile-image mx-auto d-block"
          src="https://avatars0.githubusercontent.com/u/32352247?s=400&v=4"
          alt="Manas Kinkar"
          loading="eager"
          decoding="async"
          style="max-width: 300px; width: 100%;"
        />
      </div>
    </div>
  </section>

  <section class="container pb-5">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body text-center">
            <h3 class="h5">25%</h3>
            <p class="text-muted mb-0">Cost reduction per transaction</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body text-center">
            <h3 class="h5">10x</h3>
            <p class="text-muted mb-0">Throughput increase</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body text-center">
            <h3 class="h5">1.5M+</h3>
            <p class="text-muted mb-0">Transactions processed daily</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
