---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";
---

<BaseLayout
  title="Projects | Manas Kinkar"
  description="Projects by Manas Kinkar, including software builds and experiments."
  path="/projects/"
>
  <section class="container py-5">
    <h1 class="mb-3">Projects</h1>
    <p class="text-muted mb-4">
      A selection of software projects focused on practical outcomes and clean implementation.
    </p>
    <div class="row g-3">
      {
        projects.map((project) => (
          <div class="col-md-6 col-xl-4">
            <article class="card h-100">
              <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">{project.title}</h2>
                <p class="card-text text-muted">{project.summary}</p>
                <p class="mt-auto mb-3">
                  <strong>Stack:</strong> {project.stack.join(", ")}
                </p>
                <div class="d-flex gap-2 flex-wrap">
                  {project.repoUrl && (
                    <a class="btn btn-sm btn-outline-info" href={project.repoUrl}>
                      Repository
                    </a>
                  )}
                  {project.demoUrl && (
                    <a class="btn btn-sm btn-info" href={project.demoUrl}>
                      Live demo
                    </a>
                  )}
                </div>
              </div>
            </article>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
