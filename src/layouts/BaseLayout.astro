---
import "../styles/global.css";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import Seo from "../components/Seo.astro";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = "/" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#fafaf9" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
    <Seo title={title} description={description} path={path} />
  </head>
  <body>
    <!-- Decorative emojis matching blogs theme -->
    <aside class="emoji-decoration emoji-left" aria-hidden="true" style="position: fixed; top: 50%; left: clamp(1rem, 3vw, 2.5rem); transform: translateY(-50%); z-index: 5; pointer-events: none;">
      <div style="display: flex; flex-direction: column; gap: 2rem; align-items: center;">
        <span style="font-size: 2rem; opacity: 0.6;">💻</span>
        <span style="font-size: 2rem; opacity: 0.6;">🚀</span>
        <span style="font-size: 2rem; opacity: 0.6;">📊</span>
      </div>
    </aside>
    <aside class="emoji-decoration emoji-right" aria-hidden="true" style="position: fixed; top: 50%; right: clamp(1rem, 3vw, 2.5rem); transform: translateY(-50%); z-index: 5; pointer-events: none;">
      <div style="display: flex; flex-direction: column; gap: 2rem; align-items: center;">
        <span style="font-size: 2rem; opacity: 0.6;">⚙️</span>
        <span style="font-size: 2rem; opacity: 0.6;">🧠</span>
        <span style="font-size: 2rem; opacity: 0.6;">📚</span>
      </div>
    </aside>

    <a class="skip-link" href="#content">Skip to content</a>
    <NavBar />
    <main id="content">
      <slot />
    </main>
    <Footer />

    <style>
      @media (max-width: 768px) {
        .emoji-decoration {
          display: none !important;
        }
      }
    </style>
  </body>
</html>
