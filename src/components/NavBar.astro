---
const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/projects/", label: "Projects" },
  { href: "/experience/", label: "Experience" },
  { href: "/blogs/", label: "Blog" }
];
---

<header class="border-bottom border-secondary-subtle">
  <nav class="navbar" aria-label="Primary navigation">
    <div class="container py-3 d-flex flex-column flex-md-row align-items-start align-items-md-center gap-2">
      <a class="navbar-brand fw-semibold text-light" href="/">Manas Kinkar</a>
      <ul class="navbar-nav ms-md-auto d-flex flex-row flex-wrap gap-2">
        {
          links.map((link) => (
            <li class="nav-item">
              <a
                class={`nav-link ${pathname === link.href ? "active fw-semibold text-light" : "text-light"}`}
                href={link.href}
                aria-current={pathname === link.href ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</header>
