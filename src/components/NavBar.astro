---
const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/projects/", label: "Projects" },
  { href: "/experience/", label: "Experience" },
  { href: "/blogs/", label: "Blog" }
];
---

<header style="background: var(--bg-elevated); border-bottom: 1px solid var(--border-light); padding: clamp(2rem, 5vw, 3rem) 0; margin-bottom: 2rem; box-shadow: var(--shadow-sm);">
  <nav aria-label="Primary navigation">
    <div class="container d-flex flex-column flex-md-row align-items-start align-items-md-center gap-3">
      <a href="/" style="font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: var(--text-primary); text-decoration: none; letter-spacing: -0.025em;">
        Manas Kinkar
      </a>
      <ul class="list-unstyled ms-md-auto d-flex flex-row flex-wrap gap-3 mb-0">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                style={`color: var(--accent-primary); text-decoration: none; font-weight: 500; padding: 0.5rem 1rem; border-radius: 6px; background: ${pathname === link.href ? 'var(--bg-secondary)' : 'transparent'}; transition: all 0.2s ease;`}
                aria-current={pathname === link.href ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</header>
